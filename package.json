{
  "name": "forme",
  "version": "0.0.1",
  "private": true,
  "description": "An editorial magazine CMS for print. Single operator. Offline. Open source.",
  "author": "Adnan Abbasi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adoistic/forme.git"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && bun scripts/post-build.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "bun run rebuild:electron",
    "test:e2e": "playwright test",
    "posttest:e2e": "bun run rebuild:node",
    "predev": "bun run rebuild:electron",
    "predist": "bun run rebuild:electron",
    "dist": "electron-builder",
    "db:migrate": "kysely-ctl migrate latest",
    "db:migrate:down": "kysely-ctl migrate down",
    "db:status": "kysely-ctl migrate list",
    "rebuild:electron": "electron-rebuild -w better-sqlite3 -f",
    "rebuild:node": "cd node_modules/better-sqlite3 && ../.bin/prebuild-install --runtime=node --target=$(node -p process.versions.node) >/dev/null 2>&1 || true",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "docx": "^9.6.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "kysely-ctl": "^0.20.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.9",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "better-sqlite3": "^12.9.0",
    "immer": "^11.1.4",
    "kysely": "^0.28.16",
    "mammoth": "^1.12.0",
    "papaparse": "^5.5.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  }
}
